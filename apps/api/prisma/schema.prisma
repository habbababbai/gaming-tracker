generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "commonjs"
}

datasource db {
  provider = "postgresql"
}

enum GameStatus {
  todo
  playing
  completed
  dropped
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  userGames UserGame[]

  @@index([email])
}

model Game {
  id          String   @id @default(cuid())
  name        String
  igdbId      Int?     @unique
  coverUrl    String?
  releaseYear Int?
  createdAt   DateTime @default(now())

  userGames UserGame[]

  @@index([name])
  @@index([igdbId])
}

model UserGame {
  id        String     @id @default(cuid())
  userId    String
  gameId    String
  status    GameStatus @default(todo)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@index([userId, status])
}
