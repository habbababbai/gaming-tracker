{
    "name": "gaming-tracker",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "packageManager": "bun@1.3.6",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "lint:fix": "turbo lint:fix",
        "changelog:generate": "node scripts/generate-changelog.js",
        "changelog:test": "node scripts/generate-changelog.js --json"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "turbo": "^2.8.13"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "husky": "^9.1.7"
    }
}
